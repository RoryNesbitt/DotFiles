#!/bin/sh

if [ $# = 0 ]; then
  tmux list-sessions
else
  if [ "$1" = 'w' ]; then
    session='work'
  elif [ "$1" = config ]; then
    session='conf-'$2
  else
    session=$1
  fi
  shift

  if ! tmux has-session -t "$session" 2>/dev/null; then
    case "$session" in
    'update')
      tmux new -s "$session" -d "fullUpdate; read key <&1"
      ;;
    'work' | 'uni' | 'papers' | 'projects')
      tmux new -s "$session" -d -c ~/Documents/"$session" "$@"
      ;;
    'notes')
      tmux new -s "$session" -d "$EDITOR"
      ;;
    'scripts')
      tmux new -s "$session" -d -c ~/.local/scripts "$EDITOR $@"
      ;;
    'conf-'*)
      tmux new -s "$session" -d -c ~/.config/"$1" "$EDITOR"
      ;;
    *)
      ssh_hosts=$(awk '/^Host /{print $2}' "$HOME/.ssh/config")
      if echo "$ssh_hosts" | grep -qx "$session"; then
        tmux new -s "ssh-$session" -d "ssh $session || read key <&1"
        session="ssh-$session"
      else
        tmux new -s "$session" -d "$@"
      fi
      ;;
    esac
  fi # has-session

  if [ -z "$TMUX" ]; then
    tmux attach-session -t "$session"
  else
    tmux switch-client -t "$session"
  fi # if $TMUX
fi  # if $#

